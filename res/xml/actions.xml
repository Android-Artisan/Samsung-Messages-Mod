<?xml version="1.0" encoding="utf-8"?>
<actions>
    <action intentName="sec.actions.intent.OPEN_MESSAGE">
        <parameter name="message.name" type="http://schema.org/Text" />
        <parameter name="message.contentUrl" type="http://schema.org/URL" />
        <fulfillment urlTemplate="intent:{url}#Intent;package=com.samsung.android.messaging;end">
            <parameter-mapping intentParameter="message.name" required="false" urlParameter="name" />
            <parameter-mapping intentParameter="message.contentUrl" required="true" urlParameter="url" />
        </fulfillment>
    </action>
</actions>
