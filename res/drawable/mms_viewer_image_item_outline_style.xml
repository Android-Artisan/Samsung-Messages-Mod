<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <stroke android:width="2.0dp" android:color="#001f76" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <stroke android:width="2.0dp" android:color="#ff0004" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <stroke android:width="2.0dp" android:color="#62ff81" />
        </shape>
    </item>
</selector>
