<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/attachment_stroke_radius" />
                    <solid android:color="@color/theme_bubble_color_bg_received" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/attachment_stroke_radius" />
                    <solid android:color="@color/bubble_received_item_pressed_color" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/attachment_stroke_radius" />
            <solid android:color="@color/theme_bubble_color_bg_received" />
            <stroke android:width="@dimen/attachment_stroke_normal_press_width" android:color="@color/attach_file_bubble_stroke" />
        </shape>
    </item>
</selector>
