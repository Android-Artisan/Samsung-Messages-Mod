<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/air_view_button_bg_color" />
            <corners android:radius="@dimen/air_view_button_radius" />
        </shape>
    </item>
    <item>
        <ripple android:color="@color/air_view_ripple_color">
            <item android:id="@android:id/mask">
                <shape android:shape="rectangle">
                    <solid android:color="@color/air_view_button_bg_color" />
                    <corners android:radius="@dimen/air_view_button_radius" />
                </shape>
            </item>
        </ripple>
    </item>
    <item android:gravity="center" android:drawable="@drawable/messages_air_view_save" />
</layer-list>
