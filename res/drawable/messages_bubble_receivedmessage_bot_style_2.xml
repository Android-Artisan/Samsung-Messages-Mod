<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/bubble_bot_card_background_color" />
            <stroke android:width="@dimen/bubble_bot_stroke" android:color="@color/theme_bubble_rich_card_stroke_color" />
            <corners android:radius="@dimen/bubble_bot_radius" />
        </shape>
    </item>
    <item android:state_focused="true" android:drawable="@drawable/messages_bubble_receivedmessage_bot_group">
        <shape>
            <solid android:color="@color/bubble_bot_card_background_color" />
            <stroke android:width="@dimen/bubble_bot_stroke" android:color="@color/theme_bubble_rich_card_stroke_color" />
            <corners android:radius="@dimen/bubble_bot_radius" />
        </shape>
    </item>
    <item android:state_selected="true" android:drawable="@drawable/messages_bubble_receivedmessage_bot_group">
        <shape>
            <solid android:color="@color/bubble_bot_card_background_color" />
            <stroke android:width="@dimen/bubble_bot_stroke" android:color="@color/theme_bubble_rich_card_stroke_color" />
            <corners android:radius="@dimen/bubble_bot_radius" />
        </shape>
    </item>
    <item android:state_enabled="true" android:drawable="@drawable/messages_bubble_receivedmessage_bot_group">
        <shape>
            <solid android:color="@color/bubble_bot_card_background_color" />
            <stroke android:width="@dimen/bubble_bot_stroke" android:color="@color/theme_bubble_rich_card_stroke_color" />
            <corners android:radius="@dimen/bubble_bot_radius" />
        </shape>
    </item>
</selector>
