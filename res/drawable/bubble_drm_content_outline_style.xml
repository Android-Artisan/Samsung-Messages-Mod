<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <stroke android:width="2.0px" android:color="#001f76" />
            <corners android:radius="@dimen/bubble_corner_radius" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <stroke android:width="2.0px" android:color="#ff0004" />
            <corners android:radius="@dimen/bubble_corner_radius" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <stroke android:width="2.0px" android:color="#62ff81" />
            <corners android:radius="@dimen/bubble_corner_radius" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke android:width="2.0px" android:color="#b3b3b3" />
            <solid android:color="#fafafa" />
            <corners android:radius="@dimen/bubble_corner_radius" />
        </shape>
    </item>
</selector>
