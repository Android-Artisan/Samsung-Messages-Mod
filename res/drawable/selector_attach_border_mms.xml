<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <androidx.appcompat.util.SeslShapeDrawable android:shape="rectangle">
                    <corners android:radius="@dimen/attachment_preview_stroke_radius" />
                    <stroke android:width="@dimen/attachment_stroke_normal_press_width" android:color="@color/mms" />
                </androidx.appcompat.util.SeslShapeDrawable>
            </item>
            <item>
                <androidx.appcompat.util.SeslShapeDrawable android:shape="rectangle">
                    <corners android:radius="@dimen/attachment_preview_stroke_radius" />
                    <stroke android:width="@dimen/attachment_stroke_normal_press_width" android:color="@color/item_pressed_color" />
                    <solid android:color="@color/item_pressed_color" />
                </androidx.appcompat.util.SeslShapeDrawable>
            </item>
        </layer-list>
    </item>
    <item>
        <androidx.appcompat.util.SeslShapeDrawable android:shape="rectangle">
            <corners android:radius="@dimen/attachment_preview_stroke_radius" />
            <stroke android:width="@dimen/attachment_stroke_normal_press_width" android:color="@color/attach_file_bubble_stroke" />
        </androidx.appcompat.util.SeslShapeDrawable>
    </item>
</selector>
