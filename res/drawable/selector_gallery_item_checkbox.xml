<?xml version="1.0" encoding="utf-8"?>
<selector android:enterFadeDuration="333" android:exitFadeDuration="333"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item android:drawable="@drawable/gallery_btn_uncheck_bg_mtrl" />
            <item android:drawable="@drawable/check_box_attach_selected" />
        </layer-list>
    </item>
    <item android:state_checked="false">
        <layer-list>
            <item android:drawable="@drawable/gallery_btn_uncheck_bg_mtrl" />
            <item android:drawable="@drawable/theme_drawer_check_box_off_image" />
        </layer-list>
    </item>
</selector>
