<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <ripple android:color="@color/ripple_color">
            <item android:id="@android:id/mask">
                <androidx.appcompat.util.SeslShapeDrawable android:shape="rectangle">
                    <solid android:color="@color/color_white" />
                    <corners android:radius="@dimen/viewer_transfer_button_radius" />
                </androidx.appcompat.util.SeslShapeDrawable>
            </item>
        </ripple>
    </item>
    <item>
        <inset>
            <androidx.appcompat.util.SeslShapeDrawable android:shape="rectangle">
                <solid android:color="@color/transfer_button_bg_color" />
                <corners android:radius="@dimen/viewer_transfer_button_radius" />
            </androidx.appcompat.util.SeslShapeDrawable>
        </inset>
    </item>
</layer-list>
