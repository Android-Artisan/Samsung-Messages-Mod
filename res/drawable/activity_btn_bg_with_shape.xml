<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <ripple android:color="@color/ripple_color">
            <item android:id="@android:id/mask" android:drawable="@android:color/white" />
        </ripple>
    </item>
    <item>
        <inset android:insetLeft="@dimen/activity_btn_shape_padding_horizontal" android:insetRight="@dimen/activity_btn_shape_padding_horizontal" android:insetTop="@dimen/activity_btn_shape_padding_vertical" android:insetBottom="@dimen/activity_btn_shape_padding_vertical">
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/activity_btn_shape_radius" />
                <solid android:color="@color/btn_shape_bg_color" />
                <stroke android:width="@dimen/activity_btn_shape_stroke" android:color="@color/show_button_bg_stroke_color" />
            </shape>
        </inset>
    </item>
</layer-list>
