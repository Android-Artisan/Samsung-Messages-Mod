<LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="@dimen/attach_more_grid_margin_side" android:paddingVertical="@dimen/attach_more_grid_margin_top_bottom"
  xmlns:android="http://schemas.android.com/apk/res/android">
