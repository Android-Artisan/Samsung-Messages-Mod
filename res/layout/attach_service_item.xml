        <LinearLayout android:gravity="center" android:id="@id/service_icon_container" android:background="@drawable/attach_more_item_background" android:layout_width="@dimen/attach_more_icon_background" android:layout_height="@dimen/attach_more_icon_background" android:layout_centerHorizontal="true">
