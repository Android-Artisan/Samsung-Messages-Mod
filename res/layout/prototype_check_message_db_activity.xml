<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:focusable="true" android:focusableInTouchMode="true" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="15.0dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="check message's conversation id and thread id" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@id/do_check" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Do Check" />
            <Button android:id="@id/view_nok_list" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View NOK List" />
            <Button android:id="@id/view_ok_list" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View OK List" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textSize="15.0dp" android:id="@id/show_result" android:scrollbars="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nothing" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
