<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:background="@color/list_activity_background_color" android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="@dimen/first_launch_padding" android:paddingHorizontal="@dimen/first_launch_padding">
            <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/number_entry_top_margin">
                <TextView android:textSize="@dimen/number_entry_title_text_size" android:textColor="@color/number_entry_title_text_color" android:ellipsize="end" android:gravity="center" android:layout_gravity="center_vertical" android:id="@id/number_entry_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/number_entry_title" />
                <TextView android:textSize="@dimen/number_entry_description_text_size" android:textColor="@color/number_entry_description_text_color" android:gravity="center" android:layout_gravity="center_vertical" android:id="@id/number_entry_description" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/number_entry_description_top_margin" android:layout_marginBottom="@dimen/number_entry_description_bottom_margin" android:text="@string/number_entry_description" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <TextView android:textSize="@dimen/number_entry_textview_text_size" android:textColor="@color/colorPrimary" android:ellipsize="end" android:id="@id/number_entry_country_code" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/number_entry_country_code" android:maxLines="1" />
                    <TextView android:textSize="@dimen/number_entry_input_text_size" android:textColor="@color/number_entry_edit_text_color" android:id="@id/text_view_for_dropdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8.0dp" android:singleLine="true" android:drawableRight="@drawable/spinner_drop_down_arrow" android:backgroundTint="@color/number_entry_edit_text_color" />
                    <View android:background="@color/colorPrimary" android:layout_width="match_parent" android:layout_height="1.0dp" />
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginStart="@dimen/number_entry_country_number_gap">
                    <TextView android:textSize="@dimen/number_entry_textview_text_size" android:textColor="@color/colorPrimary" android:ellipsize="end" android:id="@id/number_entry_your_phone_number" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/number_entry_phone_number" android:maxLines="1" android:elegantTextHeight="false" />
                    <EditText android:textSize="@dimen/number_entry_input_text_size" android:textColor="@color/number_entry_edit_text_color" android:id="@id/number_entry_your_phone_number_input" android:background="@android:color/transparent" android:layout_width="match_parent" android:layout_height="0.0dp" android:maxLines="1" android:maxLength="30" android:layout_weight="1.0" android:inputType="numberDecimal">
                        <requestFocus />
                    </EditText>
                    <View android:background="@color/colorPrimary" android:layout_width="match_parent" android:layout_height="1.0dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:layout_weight="1.0" />
        <LinearLayout android:layout_gravity="bottom" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="5.0dp" android:layout_weight="0.0">
            <Button android:textColor="@color/colorPrimaryDark" android:id="@id/number_entry_skip_button" android:minHeight="@dimen/number_entry_button_height" android:text="@string/first_launch_button_skip" android:maxLines="1" android:layout_marginEnd="5.0dp" style="@style/ButtonBarButtonStyle" />
            <Button android:textColor="@color/colorPrimaryDark" android:id="@id/number_entry_continue_button" android:minHeight="@dimen/number_entry_button_height" android:text="@string/first_launch_button_continue" android:maxLines="1" android:layout_marginStart="5.0dp" style="@style/ButtonBarButtonStyle" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
