<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="@dimen/gallery_resolution_popup_start_end_padding" android:paddingEnd="@dimen/gallery_resolution_popup_start_end_padding"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:id="@id/item_container" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentStart="true">
        <ImageView android:layout_gravity="center_vertical" android:id="@id/item_img" android:layout_width="@dimen/gallery_resolution_popup_icon_size" android:layout_height="@dimen/gallery_resolution_popup_icon_size" android:src="@drawable/resolution_full_ic" android:tint="@color/theme_bottom_bar_icon_color" />
