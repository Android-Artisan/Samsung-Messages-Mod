{
  "template": {
    "schema_name": "com.samsung.android.messaging.message",
    "query_template_name": "search"
  },
  "query":{
    "text":"$0",
    "bool":{
      "must_not":[
        {
          "match":{
            "text": 15,
            "fields":[
              "message_type"
            ]
          }
        }
      ],
      "should":[
        {
          "bool": {
            "must_not": [
              {
                "exists": {
                  "fields": [
                    "re_body"
                  ]
                }
              }
            ],
            "should": [
              {
                "bool": {
                  "should": [
                    {
                      "prefix": {
                        "fields": [
                          "subject_decompose"
                        ],
                        "term_operator": "and"
                      }
                    },
                    {
                      "chosung": {
                        "fields": [
                          "subject"
                        ],
                        "chosung_field": "subject_chosung",
                        "term_operator": "and"
                      }
                    },
                    {
                      "term": {
                        "fields": [
                          "subject_initial"
                        ],
                        "term_operator": "and"
                      }
                    }
                  ]
                }
              },
              {
                "bool": {
                  "should": [
                    {
                      "prefix": {
                        "fields": [
                          "part_search_text_decompose"
                        ],
                        "term_operator": "and"
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "bool":{
            "should":[
              {
                "prefix": {
                  "fields": [
                    "re_body_decompose"
                  ],
                  "term_operator": "and"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "fallback_queries":[
    {
      "text":"$0",
      "bool":{
        "must_not":[
          {
            "match":{
              "text": 15,
              "fields":[
                "message_type"
              ]
            }
          }
        ],
        "should":[
          {
            "bool": {
              "must_not": [
                {
                  "exists": {
                    "fields": [
                      "re_body"
                    ]
                  }
                }
              ],
              "should": [
                {
                  "bool": {
                    "should": [
                      {
                        "phonetic": {
                          "fields": [
                            "subject_phonetic"
                          ],
                          "term_operator": "and"
                        }
                      },
                      {
                        "prefix": {
                          "fields": [
                            "subject_transliterated"
                          ],
                          "term_operator": "and"
                        }
                      }
                    ]
                  }
                },
                {
                  "phonetic": {
                    "fields": [
                      "part_search_text_phonetic"
                    ],
                    "term_operator": "and"
                  }
                }
              ]
            }
          },
          {
            "phonetic": {
              "fields": [
                "re_body_phonetic"
              ],
              "term_operator": "and"
            }
          }
        ]
      }
    },
    {
      "text":"$0",
      "bool":{
        "must_not":[
          {
            "match":{
              "text": 15,
              "fields":[
                "message_type"
              ]
            }
          }
        ],
        "should":[
          {
            "bool": {
              "must_not": [
                {
                  "exists": {
                    "fields": [
                      "re_body"
                    ]
                  }
                }
              ],
              "should": [
                {
                  "fuzzy": {
                    "fields": [
                      "subject_fuzzy",
                      "part_search_text_fuzzy"
                    ],
                    "minimum_length": 5,
                    "fuzziness": 1,
                    "term_operator": "and"
                  }
                }
              ]
            }
          },
          {
            "fuzzy": {
              "fields": [
                "re_body_fuzzy"
              ],
              "minimum_length": 5,
              "fuzziness": 1,
              "term_operator": "and"
            }
          }
        ]
      }
    }
  ],
  "sort": {
    "created_timestamp": "DESC"
  },
  "group_by": {
    "field": "message_id"
  }
}